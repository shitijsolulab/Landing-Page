# Frontend environment (Vite / TanStack Start).
# Copy to `.env`:  cp .env.example .env

# Base URL of the Industry AI OS API gateway. The frontend talks to the gateway
# ONLY — never to a service or Keycloak directly.
# NOTE: the gateway runs on :8000 because the frontend dev server uses :8080.
VITE_API_URL=http://localhost:8000
